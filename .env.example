# CodeSentry configuration. Copy to `.env` and fill in your values.

# Required: OpenAI API key used by the agent.
OPENAI_API_KEY=

# Model used for the agent and review loops. Use gpt-4.1-mini for cheap
# iteration; reserve gpt-4.1 for benchmark and demo runs.
CODESENTRY_MODEL=gpt-4.1

# Maximum tokens per LLM response.
CODESENTRY_MAX_TOKENS=4096

# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
CODESENTRY_LOG_LEVEL=INFO

# Optional: override the OpenAI base URL (e.g. for a local or proxy endpoint).
# OPENAI_BASE_URL=
